rules_version = '2';
service cloud.firestore {
  function isAdmin() {
    return request.auth != null && request.auth.token.role == "admin";
  }

  function hasUserRole() {
    return request.auth != null && (request.auth.token.role == "user" || request.auth.token.role == "admin");
  }

  function isAuthenticated() {
    return request.auth != null;
  }

  // Returns the authenticated user's company ID from custom auth claims.
  // Set by Cloud Functions when a user creates or joins a company.
  function userCompanyId() {
    return request.auth.token.companyId;
  }

  // True when the authenticated user belongs to a SUB-contractor company.
  function isSubMember() {
    return isAuthenticated() && request.auth.token.companyType == 'SUB' && userCompanyId() != null;
  }

  match /databases/{database}/documents {

    // ── Platform infrastructure (server-side only) ────────────────────────

    match /admin/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /processedWebhookEvents/{eventId} {
      allow read, write: if false;
    }

    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Firebase Auth user profiles ───────────────────────────────────────

    match /users/{uid} {
      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      allow read: if isOwner();

      allow update: if isOwner()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(["preferences", "displayName", "company", "updatedAt"])
        && (
          !("preferences" in request.resource.data.diff(resource.data).affectedKeys())
          || (
            request.resource.data.preferences.keys().hasOnly(["itemsPerPage"])
            && request.resource.data.preferences.itemsPerPage is number
          )
        );

      // Allow a user to create their own profile doc (client-side fallback when
      // the onUserCreate Cloud Function hasn't written it yet, e.g. in emulators).
      allow create: if isOwner()
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasAll(["uid", "email", "subscription", "createdAt"]);

      match /preferences/{doc} {
        allow read, write: if isOwner();
      }

      match /notifications/{notificationId} {
        allow read: if isOwner();
        allow write: if false;
      }

      match /items/{itemId} {
        allow read: if isOwner();
        allow delete: if isOwner();
        allow create: if false;
        allow update: if false;
      }
    }

    // ── FieldStack Multi-tenant ───────────────────────────────────────────

    // Company membership lookup (flat collection for querying by uid)
    match /companyMembers/{memberDocId} {
      // Users can read their own memberships
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      // Allow a user to create their own membership doc (onboarding)
      // Doc ID must be {companyId}_{uid} and the uid must match the requester
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "ADMIN";
      // No client-side updates or deletes
      allow update, delete: if false;
    }

    // Company documents
    match /companies/{companyId} {
      function isMember() {
        return isAuthenticated() &&
          exists(/databases/$(database)/documents/companyMembers/$(companyId + "_" + request.auth.uid));
      }

      function isCompanyAdmin() {
        return isAuthenticated() &&
          get(/databases/$(database)/documents/companyMembers/$(companyId + "_" + request.auth.uid)).data.role == "ADMIN";
      }

      allow read: if isMember();
      // Allow authenticated users to create a new company (onboarding)
      allow create: if isAuthenticated() && request.resource.data.id == companyId;
      // Updates/deletes are server-side only
      allow update, delete: if false;

      // Project connections — GC company members read only; server writes
      // Doc ID convention: {gcProjectId}_{subCompanyId}
      match /projectConnections/{connectionId} {
        allow read: if isMember();
        allow write: if false;
      }

      // Projects
      match /projects/{projectId} {
        // True when an authenticated Sub user has an active connection to this GC project.
        // Requires a projectConnection doc at companies/{companyId}/projectConnections/{projectId}_{subCompanyId}
        // with status == 'active'. The doc ID convention is enforced by the server invite flow.
        function hasActiveSubConnection() {
          return isSubMember()
            && exists(/databases/$(database)/documents/companies/$(companyId)/projectConnections/$(projectId + "_" + userCompanyId()))
            && get(/databases/$(database)/documents/companies/$(companyId)/projectConnections/$(projectId + "_" + userCompanyId())).data.status == 'active';
        }

        // GC members: full read. Sub users: read projects they are connected to.
        allow read: if isMember() || hasActiveSubConnection();
        allow write: if false; // server-side only

        // Tasks
        match /tasks/{taskId} {
          // GC members: all tasks. Sub users: only tasks assigned to their company.
          allow read: if isMember()
            || (isSubMember()
              && resource.data.assignedSubCompanyId == userCompanyId()
              && hasActiveSubConnection());
          allow write: if false; // server-side only
        }

        match /orderItems/{itemId} {
          allow read: if isMember();
          allow write: if false;
        }

        match /scheduleChanges/{changeId} {
          allow read: if isMember();
          allow write: if false;
        }

        // Task steps
        match /taskSteps/{stepId} {
          // GC members: full read. Sub users: read all steps on their connected projects.
          allow read: if isMember() || hasActiveSubConnection();

          // GC: server-side only
          allow write: if false;

          // Sub users may update status and notes on steps where canEditBy permits.
          // They may never change dates, step type, or any other GC-owned fields.
          allow update: if isSubMember()
            && hasActiveSubConnection()
            && (resource.data.canEditBy == 'SUB' || resource.data.canEditBy == 'BOTH')
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'notes', 'updatedAt']);
        }

        match /feedEntries/{entryId} {
          allow read: if isMember();
          allow write: if false;
        }
      }

      // Team members
      match /teamMembers/{memberId} {
        allow read: if isMember();
        allow write: if false;
      }

      // Lead time settings
      match /leadTimeSettings/{settingId} {
        allow read: if isMember();
        // Allow company admins to create/update lead time settings
        allow create, update: if isCompanyAdmin();
        allow delete: if false;
      }

      // Chat messages — members can read their company's chat
      match /chatMessages/{messageId} {
        allow read: if isMember();
        allow write: if false;
      }

      // Gmail connection — admin only read (contains tokens)
      match /gmailConnection {
        allow read: if isCompanyAdmin();
        allow write: if false;
      }
    }
  }
}
